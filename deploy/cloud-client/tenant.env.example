# Optional shared env for one contractor/tenant on a production VM.
# Use it before a server-specific env:
# docker compose --env-file clients/demoalpha.tenant.env --env-file clients/demoalpha-cloud1.env ...
CLIENT_SLUG=demoalpha
CLIENT_BASE_DOMAIN=example.com
LICENSE_SERVER_URL=https://license.example.com

# Optional override. If omitted, compose uses CLIENT_SLUG.
LICENSE_TENANT_ID=demoalpha
