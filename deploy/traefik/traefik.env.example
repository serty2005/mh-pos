TRAEFIK_ACME_EMAIL=ops@example.com
TRAEFIK_DASHBOARD_DOMAIN=traefik.example.com

# Use an htpasswd value escaped for Docker Compose interpolation.
# Example:
#   htpasswd -nbB admin 'change-me' | sed -e 's/\$/$$/g'
TRAEFIK_DASHBOARD_BASIC_AUTH=admin:$$2y$$05$$exampleexampleexampleexampleexampleexampleexampleexampleexampleex
