[Unit]
Description=MyHoreca License Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mh-license
Group=mh-license
WorkingDirectory=/opt/myhoreca/license-server/current
EnvironmentFile=/etc/myhoreca/license-server/license-api.env
ExecStart=/opt/myhoreca/license-server/current/license-api
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/myhoreca/license-server /var/backups/myhoreca/license-server

[Install]
WantedBy=multi-user.target
