  "components": {
    "parameters": {
      "RestaurantID": {
        "name": "restaurant_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "NodeDeviceID": {
        "name": "node_device_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "ID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "LineID": {
        "name": "line_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "CreateRestaurant": {
        "type": "object",
        "required": ["name", "timezone", "currency", "business_day_mode", "business_day_boundary_local_time"]
      },
      "CreateRole": {
        "type": "object",
        "required": ["restaurant_id", "name", "permissions_json"]
      },
      "CreateEmployee": {
        "type": "object",
        "required": ["restaurant_id", "role_id", "name", "pin"]
      },
      "CreateCatalogItem": {
        "type": "object",
        "required": ["restaurant_id", "kind", "name", "sku", "base_unit"]
      },
      "CreateHall": {
        "type": "object",
        "required": ["restaurant_id", "name"]
      },
      "CreateTable": {
        "type": "object",
        "required": ["restaurant_id", "hall_id", "name", "seats"]
      },
